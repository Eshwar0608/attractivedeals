{
  "_notes": [
    "Production: Cuelinks API only, famous-brand allowlist, strong dedupe, promo Telegram format.",
    "Secrets: CUELINKS_API_TOKEN, CUELINKS_CHANNEL_ID, TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID.",
    "Runs every 15 minutes via GitHub Actions. Same offer is never posted twice (posted_deals.json cache)."
  ],
  "allowed_merchants_file": "allowed-merchants.json",
  "feeds": [
    {
      "name": "cuelinks-offers",
      "enabled": true,
      "type": "cuelinks_offers",
      "url": "${CUELINKS_OFFERS_URL:-}",
      "items_path": "${CUELINKS_OFFERS_ITEMS_PATH:-}",
      "api_token_env": "CUELINKS_API_TOKEN",
      "max_pages": 2,
      "per_page": 80,
      "category": "${CUELINKS_OFFERS_CATEGORY:-}",
      "merchant_field": "merchant",
      "currency": "Rs. "
    },
    {
      "name": "google-sheet-curated",
      "enabled": false,
      "url": "${GOOGLE_SHEET_CSV_URL:-}",
      "type": "csv",
      "title_field": "title",
      "url_field": "url",
      "price_field": "price",
      "original_price_field": "original_price",
      "discount_percent_field": "discount_percent",
      "coupon_field": "coupon",
      "category_field": "category",
      "description_field": "description",
      "image_field": "image_url",
      "merchant_field": "merchant",
      "links_field": "links",
      "bank_offer_field": "bank_offer",
      "message_field": "message",
      "currency": "Rs. "
    }
  ],
  "export_csv": {
    "enabled": true,
    "output_file": "out/deals.csv"
  },
  "dedupe": {
    "enabled": true,
    "state_file": "out/posted_deals.json",
    "max_entries": 20000,
    "record_on_dry_run": false
  },
  "affiliate": {
    "enabled": true,
    "network": "cuelinks",
    "channel_id_env": "CUELINKS_CHANNEL_ID",
    "source": "linkkit",
    "required": true
  },
  "filters": {
    "min_discount_percent": 0,
    "min_savings_amount": 0,
    "require_discount_data": false,
    "blocked_keywords": [
      "refurbished",
      "used",
      "renewed",
      "expired",
      "out of stock",
      "tatacliq",
      "nykaa",
      "snapdeal",
      "shopclues",
      "dominos",
      "pizza hut",
      "makemytrip",
      "bookmyshow"
    ],
    "required_keywords": [],
    "require_allowed_merchants": true,
    "max_items": 8
  },
  "hashtags": [],
  "message_format": {
    "style": "promo",
    "include_hashtags": false
  },
  "telegram": {
    "enabled": true,
    "bot_token_env": "TELEGRAM_BOT_TOKEN",
    "chat_id_env": "TELEGRAM_CHAT_ID",
    "disable_web_page_preview": false,
    "send_photo_when_image_available": true,
    "photo_caption_max_length": 1024,
    "timeout_seconds": 25,
    "required": true
  },
  "messages_output": {
    "output_file": "out/messages.txt"
  }
}
