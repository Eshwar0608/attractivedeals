{
  "_notes": [
    "Curated deals from Google Sheet only — filtered to your allowed merchants, optional product images, Telegram photo posts.",
    "Sheet columns: title, url, price, original_price, discount_percent, coupon, category, description, image_url",
    "image_url must be a direct https image link (JPG/PNG) that Telegram can fetch. Copy product image URL from the store page or Cuelinks offer.",
    "Set GOOGLE_SHEET_CSV_URL, CUELINKS_CHANNEL_ID, TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID. No CUELINKS_API_TOKEN required."
  ],
  "feeds": [
    {
      "name": "google-sheet-curated",
      "enabled": true,
      "url": "${GOOGLE_SHEET_CSV_URL:-}",
      "type": "csv",
      "title_field": "title",
      "url_field": "url",
      "price_field": "price",
      "original_price_field": "original_price",
      "discount_percent_field": "discount_percent",
      "coupon_field": "coupon",
      "category_field": "category",
      "description_field": "description",
      "image_field": "image_url",
      "currency": "Rs. "
    }
  ],
  "export_csv": {
    "enabled": true,
    "output_file": "out/deals.csv"
  },
  "dedupe": {
    "enabled": true,
    "state_file": "out/posted_deals.json",
    "max_entries": 10000,
    "record_on_dry_run": false
  },
  "affiliate": {
    "enabled": true,
    "network": "cuelinks",
    "channel_id_env": "CUELINKS_CHANNEL_ID",
    "source": "linkkit",
    "required": true
  },
  "filters": {
    "min_discount_percent": 10,
    "min_savings_amount": 0,
    "require_discount_data": false,
    "blocked_keywords": ["refurbished", "used", "renewed", "expired", "out of stock"],
    "required_keywords": [],
    "allowed_merchants": [
      "amazon",
      "flipkart",
      "myntra",
      "meesho",
      "ajio",
      "rare rabbit",
      "lenskart",
      "nike",
      "woodland",
      "zomato",
      "blinkit",
      "swiggy",
      "zepto",
      "bigbasket",
      "rapido",
      "uber",
      "ola",
      "fnp",
      "kfc",
      "recharge",
      "phonepe",
      "paytm"
    ],
    "max_items": 10
  },
  "hashtags": ["#deals", "#offers", "#shopping"],
  "telegram": {
    "enabled": true,
    "bot_token_env": "TELEGRAM_BOT_TOKEN",
    "chat_id_env": "TELEGRAM_CHAT_ID",
    "disable_web_page_preview": false,
    "send_photo_when_image_available": true,
    "photo_caption_max_length": 1024,
    "timeout_seconds": 20,
    "required": true
  },
  "whatsapp": {
    "output_file": "out/whatsapp_deals.txt",
    "auto_send": false
  }
}
