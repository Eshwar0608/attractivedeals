{
  "_notes": [
    "Fully scheduled simple setup: publish a Google Sheet as CSV, set GOOGLE_SHEET_CSV_URL, set CUELINKS_CHANNEL_ID, and GitHub Actions can fetch/post automatically.",
    "Expected sheet columns: merchant, title, url, price, original_price, discount_percent, coupon, category, description, image_url (see google-sheet-template.csv).",
    "The script wraps each accepted URL through Cuelinks linksredirect.com before Telegram and WhatsApp output.",
    "Only URLs from stores in allowed-merchants.json are posted."
  ],
  "allowed_merchants_file": "allowed-merchants.json",
  "feeds": [
    {
      "name": "google-sheet-deals",
      "enabled": true,
      "url": "${GOOGLE_SHEET_CSV_URL:-}",
      "type": "csv",
      "title_field": "title",
      "url_field": "url",
      "price_field": "price",
      "original_price_field": "original_price",
      "discount_percent_field": "discount_percent",
      "coupon_field": "coupon",
      "category_field": "category",
      "description_field": "description",
      "image_field": "image_url",
      "merchant_field": "merchant",
      "currency": "Rs. "
    }
  ],
  "affiliate": {
    "enabled": true,
    "network": "cuelinks",
    "channel_id_env": "CUELINKS_CHANNEL_ID",
    "source": "linkkit",
    "required": true
  },
  "filters": {
    "min_discount_percent": 20,
    "min_savings_amount": 0,
    "require_discount_data": true,
    "blocked_keywords": ["refurbished", "used", "renewed", "expired", "out of stock"],
    "required_keywords": [],
    "max_items": 10
  },
  "hashtags": ["#deals", "#offers", "#shopping"],
  "telegram": {
    "enabled": true,
    "bot_token_env": "TELEGRAM_BOT_TOKEN",
    "chat_id_env": "TELEGRAM_CHAT_ID",
    "disable_web_page_preview": false,
    "send_photo_when_image_available": true,
    "photo_caption_max_length": 1024,
    "timeout_seconds": 20,
    "required": true
  },
  "whatsapp": {
    "output_file": "out/whatsapp_deals.txt"
  }
}
